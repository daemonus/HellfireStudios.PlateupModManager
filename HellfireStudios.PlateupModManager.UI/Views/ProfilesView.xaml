<UserControl x:Class="HellfireStudios.PlateupModManager.UI.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#1e1e2e">
    <DockPanel Margin="24,20">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="Mod Profiles" FontSize="24" FontWeight="Bold"
                   Foreground="#cdd6f4" Margin="0,0,0,16" />

        <!-- Speed Run Mode Status -->
        <Border DockPanel.Dock="Top" Background="#45475a" CornerRadius="8" Padding="16,12" Margin="0,0,0,16"
                Visibility="{Binding IsSpeedRunModeRunning, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Cancel" Command="{Binding CancelSpeedRunModeCommand}"
                        Style="{StaticResource DangerButtonStyle}" VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🏃 Speed Run Mode Active" FontSize="15" FontWeight="SemiBold"
                               Foreground="#f9e2af" />
                    <TextBlock Text="{Binding SpeedRunStatus}" FontSize="12" Foreground="#a6adc8"
                               Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Info text -->
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="#6c7086" FontSize="12" Margin="0,0,0,16">
            Profiles store a set of mod subscriptions. Applying a profile will subscribe to its mods and unsubscribe from others.
            Use Speed Run Mode to temporarily subscribe to mods, view leaderboards, then automatically unsubscribe and relaunch clean.
        </TextBlock>

        <!-- Profiles List -->
        <ListView ItemsSource="{Binding Profiles}" Background="Transparent" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#313244" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Profile info -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                               Foreground="#cdd6f4" />
                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#a6adc8"
                                               Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Content="{Binding ExpandLabel}" Command="{Binding ToggleExpandCommand}"
                                                Background="Transparent" BorderThickness="0" Foreground="#89b4fa"
                                                FontSize="12" Padding="0" Margin="0,0,16,0" Cursor="Hand" />
                                        <TextBlock Text="{Binding UpdatedAt, StringFormat='Updated: {0}'}"
                                                   FontSize="11" Foreground="#6c7086" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                    <Button Content="▶ Apply"
                                            Command="{Binding DataContext.ApplyProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,6,0" />
                                    <Button Content="🏃 Speed Run"
                                            Command="{Binding DataContext.SpeedRunModeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource WarningButtonStyle}" Margin="0,0,6,0"
                                            Visibility="{Binding IsSpeedRunProfile, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="🗑 Delete"
                                            Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />
                                </StackPanel>
                            </Grid>

                            <!-- Expandable mod list -->
                            <Border Background="#45475a" CornerRadius="6" Padding="12,8" Margin="0,10,0,0"
                                    Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl ItemsSource="{Binding Mods}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                                <TextBlock Text="•" Foreground="#6c7086" FontSize="12"
                                                           Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <Button Command="{Binding DataContext.OpenWorkshopPageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" Padding="0">
                                                    <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#89b4fa" TextDecorations="Underline" />
                                                </Button>
                                                <TextBlock Text="{Binding PublishedFileId, StringFormat='  ID: {0}'}"
                                                           FontSize="11" Foreground="#6c7086" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </DockPanel>
</UserControl>
